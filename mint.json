{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Viggle API",
  "logo": {
    "dark": "/logo/viggle-logo-dark.png",
    "light": "/logo/viggle-logo.png"
  },
  "favicon": "/logo/viggle-logo.png",
  "colors": {
    "primary": "#006B24",
    "light": "#00FF41",
    "dark": "#00FF41",
    "background": {
      "dark": "#0e0e10",
      "light": "#eeeee8"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://portal.viggle.ai/dashboard"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://portal.viggle.ai/api-keys"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "anchors": [
    {
      "name": "Community",
      "icon": "https://cdn.simpleicons.org/discord/white",
      "url": "https://discord.com/invite/viggle"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": ["introduction", "authentication", "pricing"]
    },
    {
      "group": "Guides",
      "pages": [
        "guides/on-demand",
        "guides/quickstart",
        "guides/import-templates"
      ]
    },
    {
      "group": "Advanced",
      "pages": [
        "guides/compositing"
      ]
    },
    {
      "group": "Characters",
      "pages": [
        "api-reference/characters/create",
        "api-reference/characters/list",
        "api-reference/characters/get",
        "api-reference/characters/delete"
      ]
    },
    {
      "group": "Scenes",
      "pages": [
        "api-reference/scenes/create",
        "api-reference/scenes/list",
        "api-reference/scenes/get",
        "api-reference/scenes/delete",
        "api-reference/scenes/import"
      ]
    },
    {
      "group": "Render",
      "pages": [
        "api-reference/render/overview",
        "api-reference/render/create",
        "api-reference/render/multi-character",
        "api-reference/render/status",
        "api-reference/render/cancel"
      ]
    },
    {
      "group": "Credits",
      "pages": ["api-reference/credits/balance"]
    },
    {
      "group": "Reference",
      "pages": ["render-options", "error-codes"]
    }
  ],
  "footerSocials": {
    "twitter": "https://twitter.com/ViggleAI",
    "discord": "https://discord.com/invite/viggle",
    "instagram": "https://www.instagram.com/viggle_ai",
    "youtube": "https://www.youtube.com/@ViggleAI",
    "linkedin": "https://www.linkedin.com/company/viggle"
  },
  "api": {
    "baseUrl": "https://apis.viggle.ai",
    "auth": {
      "method": "bearer"
    }
  },
  "openapi": "openapi.yaml",
  "redirects": [
    {
      "source": "/errors",
      "destination": "/error-codes",
      "permanent": true
    },
    {
      "source": "/guides/live-render",
      "destination": "/guides/on-demand",
      "permanent": true
    },
    {
      "source": "/guides/fmp4-format",
      "destination": "/guides/on-demand",
      "permanent": true
    },
    {
      "source": "/guides/batch-processing",
      "destination": "/guides/on-demand",
      "permanent": true
    },
    {
      "source": "/api-reference/render/poll",
      "destination": "/api-reference/render/status",
      "permanent": true
    },
    {
      "source": "/api-reference/render/download",
      "destination": "/api-reference/render/status",
      "permanent": true
    }
  ],
  "headTags": [
    {
      "tag": "link",
      "attributes": {
        "rel": "stylesheet",
        "href": "/global.css"
      }
    },
    {
      "tag": "script",
      "attributes": {
        "src": "/scripts/copy-for-llm.js",
        "defer": "true"
      }
    }
  ]
}
